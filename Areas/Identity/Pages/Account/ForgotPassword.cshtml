@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Şifre Sıfırlama";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2">Şifremi Unuttum</h3>
                    <p class="text-muted">Kayıtlı e-posta adresinizi girmeniz durumunda, şifre sıfırlama bağlantısı tarafınıza iletilecektir.</p>
                </div>

                <form method="post">
                    @* Model üzerindeki genel hata bildirimleri *@
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-bold">E-posta Adresiniz</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" aria-required="true" placeholder="eposta@adresiniz.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold rounded-pill shadow-sm">
                        <i class="bi bi-send me-1"></i> Sıfırlama Bağlantısını Gönder
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-page="./Login" class="text-decoration-none small text-secondary">Giriş ekranına geri dön</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@* İstemci taraflı doğrulama scriptleri *@
    <partial name="_ValidationScriptsPartial" />
}