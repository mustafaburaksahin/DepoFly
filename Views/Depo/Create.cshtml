@model DepoFly.Models.Depo

@{
    ViewData["Title"] = "Yeni Depo Tanımlama";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-primary text-white py-3 rounded-top-4">
            <h4 class="mb-0 fw-bold"><i class="bi bi-building-plus me-2"></i> Yeni Depo Birimi Tanımlama</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-4">
                    <label asp-for="Ad" class="fw-bold mb-2 text-dark">Depo Tanımı / Adı</label>
                    <input asp-for="Ad" class="form-control form-control-lg border-2 shadow-sm" placeholder="Örn: Ana Dağıtım Merkezi, B-Blok Lojistik Alanı" style="border-radius: 10px;" />
                    <span asp-validation-for="Ad" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Konum" class="fw-bold mb-2 text-dark">Fiziksel Lokasyon Bilgisi (İsteğe Bağlı)</label>
                    <input asp-for="Konum" class="form-control form-control-lg border-2 shadow-sm" placeholder="Adres, kat veya reyon detaylarını belirtiniz..." style="border-radius: 10px;" />
                    <span asp-validation-for="Konum" class="text-danger"></span>
                </div>

                <div class="mt-4 pt-2 border-top">
                    <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold rounded-pill shadow">
                        <i class="bi bi-check-lg me-2"></i> Birimi Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill ms-2 px-4">Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}