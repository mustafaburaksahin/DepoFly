@model DepoFly.Models.Depo

@{
    ViewData["Title"] = "Depo Bilgilerini Düzenle";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-warning text-dark py-3 rounded-top-4">
            <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Kayıtlı Depo Bilgilerini Güncelle</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @* Kayıt tanımlayıcı verisi *@
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-4">
                    <label asp-for="Ad" class="fw-bold mb-2 text-dark">Depo Tanımı / Adı</label>
                    <input asp-for="Ad" class="form-control form-control-lg border-2 shadow-sm" placeholder="İlgili birimin adını giriniz..." style="border-radius: 10px;" />
                    <span asp-validation-for="Ad" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Konum" class="fw-bold mb-2 text-dark">Fiziksel Lokasyon (Opsiyonel)</label>
                    <input asp-for="Konum" class="form-control form-control-lg border-2 shadow-sm" placeholder="Raf, kat veya adres bilgisi belirtiniz..." style="border-radius: 10px;" />
                    <span asp-validation-for="Konum" class="text-danger"></span>
                </div>

                <div class="mt-4 pt-2 border-top">
                    <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold rounded-pill shadow">
                        <i class="bi bi-save me-2"></i> Değişiklikleri Onayla
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill ms-2 px-4">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        // İstemci tarafı doğrulama scriptleri dahil edilmiştir
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}