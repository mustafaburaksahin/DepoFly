@model IEnumerable<DepoFly.Models.Depo>

@{
    ViewData["Title"] = "Depo Yönetimi";
    Layout = "_UserLayout";
    // Erişim yetki seviyesi kontrol edilmektedir
    bool sadeceOkuma = ViewBag.SadeceOkuma ?? false;
}

<div class="container-fluid mt-4">
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center py-3">
            <div>
                <h3 class="fw-bold text-dark mb-0">
                    <i class="bi bi-building text-primary"></i> Kayıtlı Depo Birimleri
                </h3>
                <p class="text-muted small mb-0">Sistem genelinde toplam @Model.Count() aktif depo tanımlanmıştır.</p>
            </div>

            @* YÖNETİCİ AKSİYONLARI: Sadece yetkili kullanıcılar erişebilir *@
            @if (!sadeceOkuma)
            {
                <a asp-action="Create" class="btn btn-primary btn-lg rounded-3 shadow-sm fw-bold">
                    <i class="bi bi-plus-lg"></i> Yeni Depo Tanımla
                </a>
            }
            else
            {
                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-eye-fill me-1"></i> Salt Okunur Erişim
                </span>
            }
        </div>
    </div>

    @* Depo Veri Tablosu *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Depo Tanımı</th>
                            <th>Coğrafi Konum / Adres</th>
                            @if (!sadeceOkuma)
                            {
                                <th class="text-end pe-4">Yönetim İşlemleri</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="@(sadeceOkuma ? "2" : "3")" class="text-center py-4 text-muted small">Sistemde henüz tanımlanmış bir depo birimi bulunmamaktadır.</td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3 text-primary">
                                            <i class="bi bi-house-door-fill"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@item.Ad</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted small">
                                        <i class="bi bi-geo-alt me-1"></i>
                                        @(string.IsNullOrEmpty(item.Konum) ? "Konum Bilgisi Girilmemiş" : item.Konum)
                                    </span>
                                </td>

                                @* YETKİYE DAYALI İŞLEM BUTONLARI *@
                                @if (!sadeceOkuma)
                                {
                                    <td class="text-end pe-4">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1">
                                            <i class="bi bi-pencil"></i> Düzenle
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="bi bi-trash"></i> Kaldır
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Veri tablosu üzerinde dinamik filtreleme gereksinimleri için bu alan ayrılmıştır.
    </script>
}