@model DepoFly.Models.Kategori

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        @* Kategori tanımlamalarına özel görsel stil hiyerarşisi *@
        <div class="card-header bg-info text-white py-3 rounded-top-4" style="background: linear-gradient(135deg, #6610f2, #6f42c1) !important;">
            <h4 class="mb-0 fw-bold"><i class="bi bi-tag-fill me-2"></i>Yeni Kategori Tanımlama</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-4">
                    <label asp-for="Ad" class="fw-bold mb-2 text-dark">Kategori Adı</label>
                    <input asp-for="Ad" class="form-control form-control-lg border-2 shadow-sm" placeholder="Örn: Elektronik, Sarf Malzeme, Yedek Parça..." style="border-radius: 10px;" />
                    <span asp-validation-for="Ad" class="text-danger"></span>
                </div>

                <div class="mt-4 pt-2 border-top">
                    <button type="submit" class="btn btn-lg px-5 fw-bold rounded-pill shadow text-white" style="background: linear-gradient(135deg, #6610f2, #6f42c1);">
                        <i class="bi bi-check-lg me-2"></i> Kategori Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill ms-2 px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}