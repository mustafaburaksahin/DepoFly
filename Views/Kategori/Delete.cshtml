@model DepoFly.Models.Kategori

@{
    ViewData["Title"] = "Kategoriyi Sil - DepoFly";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-exclamation-octagon-fill me-2"></i> Kategori Silme Onayı
                    </h4>
                </div>

                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h5 class="text-danger fw-bold">Dikkat: "@Model.Ad" isimli kategori kalıcı olarak silinecektir.</h5>
                        <p class="text-muted small">Bu kategorinin silinmesi, ilgili kategoriye atanmış ürünlerin tanımlarını etkileyebilir.</p>
                    </div>

                    <hr class="opacity-10">

                    <div class="bg-light p-4 rounded-4 border mb-4">
                        <div class="row">
                            <div class="col-sm-4 fw-bold text-muted">Kategori Tanımı:</div>
                            <div class="col-sm-8 fw-bold text-dark">@Model.Ad</div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post" class="text-center">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-block">
                            <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill shadow-sm fw-bold">
                                <i class="bi bi-trash3-fill me-1"></i> Delete Category
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill ms-md-2 mt-2 mt-md-0">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>