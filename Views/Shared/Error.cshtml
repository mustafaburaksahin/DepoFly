@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <i class="bi bi-exclamation-triangle-fill text-danger display-1 mb-4"></i>
            <h1 class="text-danger fw-bold">İşlem Hatası</h1>
            <h2 class="text-secondary h4 mb-4">Üzgünüz, isteğiniz işlenirken teknik bir sorunla karşılaşıldı.</h2>

            @if (Model.ShowRequestId)
            {
                <div class="alert alert-light border rounded-3 d-inline-block px-4">
                    <strong>Request ID:</strong> <code class="text-dark">@Model.RequestId</code>
                </div>
            }

            <hr class="my-5 opacity-25">

            <div class="card border-0 shadow-sm rounded-4 text-start bg-light">
                <div class="card-body p-4">
                    <h3 class="h5 fw-bold text-dark"><i class="bi bi-gear-fill me-2"></i>Sistem Bilgilendirmesi</h3>
                    <p class="small text-muted">
                        Uygulama şu an yayım modundadır. Sorunun detaylarını incelemek için teknik ekibe yukarıdaki <strong>Request ID</strong> bilgisini iletebilirsiniz.
                    </p>
                    <p class="small text-muted mb-0">
                        Güvenlik gerekçesiyle, yayındaki uygulamalarda detaylı hata dökümleri (Development Mode) devre dışı bırakılmıştır. Hata ayıklama işlemleri için yerel geliştirme ortamı parametrelerinin kontrol edilmesi önerilir.
                    </p>
                </div>
            </div>

            <div class="mt-4">
                <a href="/" class="btn btn-primary rounded-pill px-4 fw-bold">
                    <i class="bi bi-house-door me-1"></i> Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>