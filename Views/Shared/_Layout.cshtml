@using Microsoft.AspNetCore.Http
@using DepoFly.Models
<!DOCTYPE html>
<html lang="tr">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - DepoFly</title>

	<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

	<style>
		body {
			font-family: 'Poppins', sans-serif;
			background-color: #f8f9fa;
			display: flex;
			flex-direction: column;
			min-height: 100vh;
		}

		.navbar {
			background-color: rgba(255, 255, 255, 0.85) !important;
			backdrop-filter: blur(12px);
			box-shadow: 0 4px 20px rgba(0,0,0,0.05) !important;
			padding: 15px 0;
			transition: all 0.3s ease;
		}

		.navbar-brand {
			font-size: 1.5rem !important;
			font-weight: 700 !important;
			letter-spacing: -0.5px;
			transition: 0.3s;
		}

		.nav-link {
			font-size: 1.05rem !important;
			font-weight: 500;
			color: #495057 !important;
			position: relative;
			padding: 8px 15px !important;
		}

			.nav-link::after {
				content: '';
				position: absolute;
				width: 0;
				height: 2px;
				bottom: 0;
				left: 50%;
				background-color: #0d6efd;
				transition: all 0.3s ease;
			}

			.nav-link:hover::after {
				width: 100%;
				left: 0;
			}

		main {
			flex: 1;
		}

		.modern-footer {
			position: relative;
			background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2000&auto=format&fit=crop');
			background-size: cover;
			background-position: center;
			color: white;
			padding: 60px 0 40px;
			margin-top: 60px;
		}

			.modern-footer::before {
				content: "";
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: rgba(15, 23, 42, 0.85);
				z-index: 1;
			}

		.footer-content {
			position: relative;
			z-index: 2;
		}
	</style>
</head>
<body>
	<header class="sticky-top" style="z-index: 1030;">
		<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom">
			<div class="container">
				<a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
					<i class="bi bi-box-seam-fill me-2 text-primary"></i>

					@if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
					{
						<span class="text-dark">DepoFly <span class="badge bg-danger ms-1" style="font-size: 12px; vertical-align: middle;">ADMIN PANEL</span></span>
					}
					else
					{
						<span style="color: #0d6efd;">DepoFly</span>
					}
				</a>

				<button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
					<span class="navbar-toggler-icon"></span>
				</button>

				<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
					<ul class="navbar-nav flex-grow-1 ms-4">
						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Index">
								<i class="bi bi-house-door me-1"></i> Ana Sayfa
							</a>
						</li>

						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Iletisim">
								<i class="bi bi-envelope me-1"></i> İletişim
							</a>
						</li>
					</ul>

					<partial name="_LoginPartial" />
				</div>
			</div>
		</nav>
	</header>

	<div class="container mt-4">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<footer class="modern-footer shadow-lg">
		<div class="container footer-content">
			<div class="row align-items-center">
				<div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
					<h4 class="fw-bold mb-2 text-white">
						<i class="bi bi-box-seam-fill text-primary"></i> DepoFly
					</h4>
					<p class="text-light mb-0" style="opacity: 0.8; font-size: 0.9rem;">
						@(User.IsInRole("Admin") ? "Yönetici Yetki Seviyesi: Sistem geneli organizasyonel denetim ve operasyonel takip merkezi." : "Modern envanter yönetim çözümleriyle depo operasyonlarınızı optimize edin.")
					</p>
				</div>
				<div class="col-md-6 text-center text-md-end">
					<span class="d-block mb-2" style="opacity: 0.8;">&copy; 2026 Tüm Hakları Saklıdır.</span>
					<div>
						<a href="https://github.com/mustafaburaksahin" class="text-white me-3" style="font-size: 1.2rem;"><i class="bi bi-github"></i></a>
						<a href="https://www.linkedin.com/in/mustafa-burak-sahin-6a20ba399/" class="text-white" style="font-size: 1.2rem;"><i class="bi bi-linkedin"></i></a>
					</div>
				</div>
			</div>
		</div>
	</footer>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>