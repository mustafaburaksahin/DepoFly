@model DepoFly.Models.Sinif
@using DepoFly.Models

@{
    ViewData["Title"] = "Sınıf Yönetimi - " + Model.SinifAdi;
    var benimRolum = (DepoFly.Models.SinifRolleri)ViewBag.BenimRolum;
}

<style>
    .admin-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
    }

    /* İsim Renk Kodları */
    .name-kurucu {
        color: #0d6efd !important;
        font-weight: 800;
    }

    .name-geciciadmin {
        color: #0dcaf0 !important;
        font-weight: 700;
    }

    .name-kullanici {
        color: #fd7e14 !important;
        font-weight: 700;
    }

    .table thead th {
        border: none;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    .user-row {
        transition: all 0.2s;
    }

        .user-row:hover {
            background-color: rgba(13, 110, 253, 0.03);
        }

    .badge-pill {
        padding: 6px 12px;
        border-radius: 50px;
        font-weight: 600;
    }

    .btn-action {
        border-radius: 10px;
        font-weight: 600;
        padding: 5px 15px;
        transition: 0.3s;
    }

    /* Filtreleme Paneli Tasarımı */
    .search-panel {
        background: white;
        border-radius: 15px;
        border: 2px solid #eee;
        transition: all 0.3s ease;
    }

        .search-panel:focus-within {
            border-color: #0d6efd;
            box-shadow: 0 5px 15px rgba(13,110,253,0.1);
        }

    /* Avatar Görsel Stili - GÜNCELLENDİ */
    .user-avatar {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }

    .user-avatar-placeholder {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6c757d, #495057);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
        border: 2px solid #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
</style>

<div class="container mt-5 pt-3">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@Model.SinifAdi</h2>
            <p class="text-muted"><i class="bi bi-info-circle me-1"></i> @Model.Aciklama</p>
        </div>
        <div class="text-end">
            <div class="d-flex align-items-center justify-content-end gap-2 mb-2">
                <span class="badge bg-primary badge-pill fs-6 shadow-sm">Katılım Kodu: @Model.KatilimKodu</span>
                <button type="button" class="btn btn-sm btn-light btn-copy-code rounded-circle shadow-sm"
                        onclick="koduKopyala('@Model.KatilimKodu')" title="Kodu Kopyala">
                    <i class="bi bi-copy"></i>
                </button>
            </div>

            <div class="d-flex flex-column align-items-end">
                <small class="text-muted mb-2">Toplam @Model.SinifKullanicilari.Count Üye</small>

                @if (benimRolum == DepoFly.Models.SinifRolleri.Kurucu)
                {
                    <form id="formSinifSil" asp-action="SinifSil" method="post" class="m-0">
                        <input type="hidden" name="sinifId" value="@Model.Id" />
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill fw-bold" onclick="sinifSilOnay()">
                            <i class="bi bi-trash3-fill me-1"></i> Sınıf Kaydını Sil
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    @* --- VERİ FİLTRELEME ALANI --- *@
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="search-panel d-flex align-items-center px-3 py-1">
                <i class="bi bi-search text-muted me-2"></i>
                <input type="text" id="uyeAra" class="form-control border-0 shadow-none py-2" placeholder="E-posta adresi ile arama yapınız...">
            </div>
        </div>
        <div class="col-md-3">
            <select id="rolFiltre" class="form-select border-2 shadow-none py-2 rounded-3">
                <option value="">Tüm Roller</option>
                <option value="Geçici Admin">Geçici Admin</option>
                <option value="Kullanıcı">Kullanıcı</option>
            </select>
        </div>
        <div class="col-md-3">
            <select id="durumFiltre" class="form-select border-2 shadow-none py-2 rounded-3">
                <option value="">Tüm Durumlar</option>
                <option value="Aktif">Aktif Üyeler</option>
                <option value="Banlı">Banlı Üyeler</option>
            </select>
        </div>
    </div>

    <div class="card admin-card shadow-lg mt-2">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-people-fill text-primary me-2"></i>Sınıf Üye Listesi</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0" id="uyeTablosu">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Üye Bilgileri</th>
                            <th>Yetki Seviyesi</th>
                            <th>Erişim Durumu</th>
                            <th class="text-end pe-4">Yönetim İşlemleri</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var uye in Model.SinifKullanicilari)
                        {
                            string nameClass = uye.SinifİciRol == DepoFly.Models.SinifRolleri.Kurucu ? "name-kurucu" :
                            (uye.SinifİciRol == DepoFly.Models.SinifRolleri.GeciciAdmin ? "name-geciciadmin" : "name-kullanici");

                            string roleText = uye.SinifİciRol == DepoFly.Models.SinifRolleri.Kurucu ? "Kurucu" :
                            (uye.SinifİciRol == DepoFly.Models.SinifRolleri.GeciciAdmin ? "Geçici Admin" : "Kullanıcı");

                            string durumText = uye.SınıftanBanliMi ? "Banlı" : "Aktif";

                            <tr class="user-row"
                                data-email="@uye.User.Email.ToLower()"
                                data-role="@roleText"
                                data-status="@durumText">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            @if (!string.IsNullOrEmpty(uye.User.ProfilFotoUrl))
                                            {
                                                @* AGA: ?v=@DateTime.Now.Ticks ekleyerek tarayıcıyı resmi tazelemeye zorluyoruz *@
                                                <img src="@uye.User.ProfilFotoUrl?v=@DateTime.Now.Ticks" class="user-avatar shadow-sm" alt="Profil">
                                            }
                                            else
                                            {
                                                <div class="user-avatar-placeholder shadow-sm">
                                                    @uye.User.Email.Substring(0, 1).ToUpper()
                                                </div>
                                            }
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="@nameClass">@uye.User.Email</span>
                                            @if (!string.IsNullOrEmpty(uye.User.UserName) && uye.User.UserName != uye.User.Email)
                                            {
                                                <small class="text-muted">@@@uye.User.UserName</small>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (uye.SinifİciRol == DepoFly.Models.SinifRolleri.Kurucu)
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary badge-pill">Admin</span>
                                    }
                                    else if (uye.SinifİciRol == DepoFly.Models.SinifRolleri.GeciciAdmin)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info badge-pill">Geçici Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary badge-pill">Kullanıcı</span>
                                    }
                                </td>
                                <td>
                                    @if (uye.SınıftanBanliMi)
                                    {
                                        <span class="text-danger fw-bold small"><i class="bi bi-slash-circle me-1"></i>Erişim Kısıtlı</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold small"><i class="bi bi-check2-circle me-1"></i>Erişim Aktif</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (uye.SinifİciRol == DepoFly.Models.SinifRolleri.Kurucu)
                                    {
                                        <span class="badge bg-light text-muted border py-2">Erişim Kısıtlı</span>
                                    }
                                    else if (benimRolum == DepoFly.Models.SinifRolleri.Kurucu)
                                    {
                                        <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                            <form asp-action="YetkiDegistir" method="post" class="d-inline m-0">
                                                <input type="hidden" name="sinifId" value="@Model.Id" />
                                                <input type="hidden" name="userId" value="@uye.UserId" />
                                                <button type="submit" class="btn btn-sm btn-warning btn-action border-0 rounded-0" title="Yetki Düzenle">
                                                    <i class="bi bi-shield-shaded text-dark"></i> <span class="text-dark small">Yetki</span>
                                                </button>
                                            </form>

                                            <form asp-action="SiniftanAt" method="post" class="d-inline m-0">
                                                <input type="hidden" name="sinifId" value="@Model.Id" />
                                                <input type="hidden" name="userId" value="@uye.UserId" />
                                                <button type="button" class="btn btn-sm btn-danger btn-action border-0 rounded-0" title="Üyeliği Sonlandır" onclick="kullaniciAtOnay(this)">
                                                    <i class="bi bi-person-x"></i> <span class="small">Çıkar</span>
                                                </button>
                                            </form>

                                            <form asp-action="SiniftanBanla" method="post" class="d-inline m-0">
                                                <input type="hidden" name="sinifId" value="@Model.Id" />
                                                <input type="hidden" name="userId" value="@uye.UserId" />
                                                <button type="submit" class="btn btn-sm btn-dark btn-action border-0 rounded-0" title="Erişimi Kısıtla">
                                                    <i class="bi bi-hammer"></i> <span class="small">@(uye.SınıftanBanliMi ? "Engel Kaldır" : "Engelle")</span>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else if (benimRolum == DepoFly.Models.SinifRolleri.GeciciAdmin && uye.SinifİciRol == DepoFly.Models.SinifRolleri.Kullanici)
                                    {
                                        <form asp-action="SiniftanBanla" method="post" class="d-inline m-0">
                                            <input type="hidden" name="sinifId" value="@Model.Id" />
                                            <input type="hidden" name="userId" value="@uye.UserId" />
                                            <button type="submit" class="btn btn-sm btn-dark btn-action shadow-sm border-0 rounded-3" title="Erişimi Kısıtla">
                                                <i class="bi bi-hammer me-1"></i> @(uye.SınıftanBanliMi ? "Engeli Kaldır" : "Engelle")
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-3 border-0 text-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-link text-muted text-decoration-none fw-bold small">
                <i class="bi bi-arrow-left me-1"></i> Ana Sayfaya Dön
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const inputAra = document.getElementById('uyeAra');
        const rolSec = document.getElementById('rolFiltre');
        const durumSec = document.getElementById('durumFiltre');
        const satirlar = document.querySelectorAll('.user-row');

        function filtreUygula() {
            const aranan = inputAra.value.toLowerCase();
            const secilenRol = rolSec.value;
            const secilenDurum = durumSec.value;

            satirlar.forEach(row => {
                const email = row.getAttribute('data-email');
                const role = row.getAttribute('data-role');
                const status = row.getAttribute('data-status');

                const metinUygun = email.includes(aranan);
                const rolUygun = secilenRol === "" || role === secilenRol;
                const durumUygun = secilenDurum === "" || status === secilenDurum;

                row.style.display = (metinUygun && rolUygun && durumUygun) ? "" : "none";
            });
        }

        inputAra.addEventListener('input', filtreUygula);
        rolSec.addEventListener('change', filtreUygula);
        durumSec.addEventListener('change', filtreUygula);

        function koduKopyala(kod) {
            navigator.clipboard.writeText(kod).then(() => {
                Swal.fire({
                    toast: true, position: 'top-end', showConfirmButton: false, timer: 2000,
                    icon: 'success', title: 'Katılım kodu kopyalandı.'
                });
            });
        }

        function sinifSilOnay() {
            Swal.fire({
                title: 'Silme Onayı',
                text: "Sınıf kaydını silmeniz durumunda tüm ilişkili veriler kalıcı olarak temizlenecektir. Bu işlem geri alınamaz.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) { document.getElementById('formSinifSil').submit(); }
            });
        }

        function kullaniciAtOnay(btnElement) {
            Swal.fire({
                title: 'İşlem Onayı',
                text: "İlgili kullanıcıyı sınıf listesinden çıkarmak istediğinize emin misiniz?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Evet, Çıkar',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) { btnElement.closest('form').submit(); }
            });
        }
    </script>
}