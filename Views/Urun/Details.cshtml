@model DepoFly.Models.Urun

@{
    ViewData["Title"] = Model.Ad + " - Ürün Detayları";
    // Controller'dan gelen yetki bilgisini alıyoruz
    bool sadeceOkuma = ViewBag.SadeceOkuma ?? false;
}

<div class="container mt-4 text-dark">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-primary text-decoration-none">Envanter Listesi</a></li>
            <li class="breadcrumb-item active text-muted" aria-current="page">@Model.Ad Detayları</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center border-0">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i> Teknik Ürün Bilgileri</h4>

                    @if (Model.StokMiktari > 10)
                    {
                        <span class="badge bg-success rounded-pill px-3"><i class="bi bi-check-circle-fill me-1"></i> Stok Mevcut</span>
                    }
                    else if (Model.StokMiktari > 0)
                    {
                        <span class="badge bg-warning text-dark rounded-pill px-3"><i class="bi bi-exclamation-triangle-fill me-1"></i> Kritik Stok Seviyesi</span>
                    }
                    else
                    {
                        <span class="badge bg-danger rounded-pill px-3"><i class="bi bi-x-circle-fill me-1"></i> Stok Tükendi</span>
                    }
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted fw-bold">Ürün Tanımı:</div>
                        <div class="col-sm-8 fs-4 fw-bold text-dark">@Model.Ad</div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted fw-bold">Kategori Tanımı:</div>
                        <div class="col-sm-8">
                            <span class="badge bg-info bg-opacity-10 text-info border border-info px-3 py-2 rounded-pill fw-bold">
                                <i class="bi bi-tag-fill me-1"></i> @(Model.Kategori?.Ad ?? "Tanımlanmamış")
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted fw-bold">Depo Lokasyonu:</div>
                        <div class="col-sm-8">
                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2 rounded-pill fw-bold">
                                <i class="bi bi-geo-alt-fill me-1"></i> @(Model.Depo?.Ad ?? "Depo Ataması Yapılmamış")
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted fw-bold">Barkod Numarası:</div>
                        <div class="col-sm-8">
                            <span class="badge bg-light border border-secondary-subtle fs-6 px-3 py-2 font-monospace shadow-sm text-dark">
                                <i class="bi bi-upc-scan me-2 text-primary"></i> @Model.Barkod
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted fw-bold">Güncel Stok Miktarı:</div>
                        <div class="col-sm-8 d-flex align-items-center">
                            <span class="badge @(Model.StokMiktari > 10 ? "bg-success" : "bg-danger") fs-6 px-3 py-2 me-2">
                                @Model.StokMiktari Adet
                            </span>
                            @if (Model.StokMiktari <= 10 && Model.StokMiktari > 0)
                            {
                                <small class="text-danger fw-bold animate-pulse"><i class="bi bi-exclamation-triangle"></i> Dikkat: Kritik Seviye</small>
                            }
                        </div>
                    </div>

                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted fw-bold">Birim Satış Fiyatı:</div>
                        <div class="col-sm-8 text-primary fw-bold fs-4">@Model.BirimFiyat.ToString("C2")</div>
                    </div>

                    <div class="row mb-0 border-top pt-3">
                        <div class="col-sm-4 text-muted fw-bold small">Sistem Kayıt Tarihi:</div>
                        <div class="col-sm-8 text-muted small">@Model.KayitTarihi.ToString("dd MMMM yyyy, dddd HH:mm")</div>
                    </div>
                </div>

                <div class="card-footer bg-white py-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                        <i class="bi bi-arrow-left"></i> Geri Dön
                    </a>

                    @if (!sadeceOkuma)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-bold rounded-pill shadow-sm text-dark">
                            <i class="bi bi-pencil-square"></i> Bilgileri Düzenle
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-white p-4 mb-4" style="background: linear-gradient(135deg, #0d6efd, #009688);">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 p-3 rounded-4 me-3">
                        <i class="bi bi-currency-dollar fs-1 text-white"></i>
                    </div>
                    <div>
                        <small class="d-block opacity-75 fw-bold">TOPLAM ENVANTER DEĞERİ</small>
                        <h3 class="mb-0 fw-bold">@((Model.StokMiktari * Model.BirimFiyat).ToString("C2"))</h3>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-lightning-charge-fill text-warning"></i> Yetkili İşlemleri</h5>
                <div class="d-grid gap-3">
                    <button class="btn btn-light border border-secondary-subtle text-start py-3 rounded-3 transition-hover" onclick="window.print()">
                        <i class="bi bi-printer text-primary me-2 fs-5"></i> <strong class="text-dark">Barkod Etiketi Yazdır</strong>
                    </button>

                    @if (!sadeceOkuma)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light border border-secondary-subtle text-start py-3 rounded-3 transition-hover">
                            <i class="bi bi-box-arrow-in-down text-success me-2 fs-5"></i> <strong class="text-dark">Stok Hareketleri</strong>
                        </a>

                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger text-start py-3 rounded-3 transition-hover">
                            <i class="bi bi-trash3 me-2 fs-5"></i> <strong>Ürün Kaydını Sil</strong>
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 border-0 rounded-3 small fw-bold">
                            <i class="bi bi-shield-lock-fill me-1"></i> Bu işlem için yetkiniz bulunmamaktadır.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.2s ease-in-out;
    }

        .transition-hover:hover {
            background-color: #f8f9fa !important;
            transform: scale(1.02);
        }

    .animate-pulse {
        animation: pulse 2s infinite;
    }


    /* Razor'un bu alanı ham metin olarak görmesini sağlar *
    /* Razor'un bu alanı ham metin olarak görmesini sağlar */
        @Html.Raw("@keyframes pulse { 0 % { opacity: 1 ; } 5 0 % { opacity: 0.5; } 100% { opacity: 1 ; } } ")

</style>