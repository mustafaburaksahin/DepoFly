@model IEnumerable<DepoFly.Models.Urun>

@if (Model != null && Model.Any())
{
    <div class="row g-4 p-3">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 urun-kart-item">
                <div class="card shadow border-0 rounded-4 h-100 overflow-hidden transition-card">

                    @* Üst Bilgi Şeridi ve Sıra Numarası *@
                    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-dark text-white rounded-circle me-2 siralama-no" style="width: 25px; height: 25px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem;">0</span>

                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3">
                                <i class="bi bi-tag-fill me-1"></i>@(item.Kategori?.Ad ?? "Kategori Atanmamış")
                            </span>
                        </div>
                        <span class="text-muted small fw-bold">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>@(item.Depo?.Ad ?? "Lokasyon Belirsiz")
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column">
                        @* Ürün Adı *@
                        <h4 class="card-title fw-bold text-dark mb-1">@item.Ad</h4>

                        @* Barkod Alanı *@
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-dark text-warning font-monospace p-2 shadow-sm" style="letter-spacing: 1px;">
                                <i class="bi bi-upc me-1"></i>@item.Barkod
                            </span>
                            <button class="btn btn-sm text-muted ms-2 p-0" onclick="copyToClipboard('@item.Barkod')" title="Copy Barcode">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>

                        @* Stok ve Fiyat Bilgileri *@
                        <div class="row g-2 mb-4">
                            <div class="col-6">
                                <div class="p-2 bg-light rounded-3 text-center border h-100">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">GÜNCEL STOK</small>
                                    <span class="fw-bold fs-5 @(item.StokMiktari < 10 ? "text-danger" : "text-success")">
                                        @item.StokMiktari <small style="font-size: 0.8rem;">Adet</small>
                                    </span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-2 bg-light rounded-3 text-center border h-100">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">BİRİM FİYAT</small>
                                    <span class="fw-bold fs-5 text-dark">
                                        @item.BirimFiyat.ToString("C2")
                                    </span>
                                </div>
                            </div>
                        </div>

                        @* İşlem Butonları *@
                        <div class="gap-2 mt-auto d-flex">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info w-100 rounded-pill fw-bold btn-sm shadow-sm text-white">
                                <i class="bi bi-eye me-1"></i> Details
                            </a>

                            @if (ViewBag.SadeceOkuma != true)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning w-100 rounded-pill fw-bold btn-sm shadow-sm text-white">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </a>
                                <button onclick="urunSilOnay(@item.Id, '@item.Ad')" class="btn btn-danger w-100 rounded-pill fw-bold btn-sm shadow-sm">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="row">
        <div class="col-12 text-center py-5">
            <div class="alert alert-light border shadow-sm p-5 rounded-4">
                <i class="bi bi-box-seam fs-1 text-muted"></i>
                <h5 class="mt-3 fw-bold text-dark">Kayıtlı ürün bulunamadı.</h5>
                <p class="text-muted">Arama kriterlerinizi güncelleyebilir veya yeni bir ürün kaydı oluşturabilirsiniz.</p>
            </div>
        </div>
    </div>
}

<form id="gizliSilmeFormu" asp-action="DeleteConfirmed" asp-controller="Urun" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="silinecekUrunId" value="" />
</form>

<script>
    // --- NUMARALANDIRMA SİSTEMİ ---
    function urunleriNumaralandir() {
        let sayac = 1;
        document.querySelectorAll('.siralama-no').forEach(el => {
            el.innerText = sayac;
            sayac++;
        });
    }

    $(document).ready(function() {
        urunleriNumaralandir();
    });

    // Barkod Kopyalama Fonksiyonu
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => {
            Swal.fire({
                toast: true, position: 'top-end', icon: 'success', title: 'Barkod panoya kopyalandı.', showConfirmButton: false, timer: 1500
            });
        });
    }

    // Ürün Silme Onay Penceresi
    function urunSilOnay(id, ad) {
        Swal.fire({
            title: 'Silme Onayı',
            text: `"${ad}" isimli ürünü silmek istediğinize emin misiniz? Bu işlem geri alınamaz.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('silinecekUrunId').value = id;
                document.getElementById('gizliSilmeFormu').submit();
            }
        });
    }
</script>

<style>
    .transition-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .bg-primary-subtle {
        background-color: #e7f1ff;
    }
</style>